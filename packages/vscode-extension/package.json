{
  "name": "arp-vscode-extension",
  "displayName": "Agent Review Protocol",
  "description": "VS Code client for the Agent Review Protocol",
  "version": "0.0.1",
  "type": "module",
  "publisher": "nodeselector",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:arp.startSession",
    "onCommand:arp.addDraftComment",
    "onCommand:arp.showDraftComments",
    "onCommand:arp.clearDraftComments",
    "onCommand:arp.submitReview",
    "onCommand:arp.showLatestBusRevision",
    "onCommand:arp.showOutput"
  ],
  "main": "./dist/vscode-extension/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "arp.startSession",
        "title": "ARP: Start Session"
      },
      {
        "command": "arp.addDraftComment",
        "title": "ARP: Add Draft Comment at Cursor"
      },
      {
        "command": "arp.showDraftComments",
        "title": "ARP: Show Draft Comments"
      },
      {
        "command": "arp.clearDraftComments",
        "title": "ARP: Clear Draft Comments"
      },
      {
        "command": "arp.submitReview",
        "title": "ARP: Submit Review"
      },
      {
        "command": "arp.showLatestBusRevision",
        "title": "ARP: Show Latest Bus Revision"
      },
      {
        "command": "arp.showOutput",
        "title": "ARP: Show Output"
      },
      {
        "command": "arp.openReviewFileDiff",
        "title": "ARP: Open Review File Diff"
      },
      {
        "command": "arp.refreshReviewFiles",
        "title": "ARP: Refresh Review Files"
      },
      {
        "command": "arp.createDraftComment",
        "title": "ARP: Create Draft Comment"
      },
      {
        "command": "arp.editDraftComment",
        "title": "ARP: Edit Draft Comment"
      },
      {
        "command": "arp.saveDraftComment",
        "title": "ARP: Save Draft Comment"
      },
      {
        "command": "arp.cancelEditDraftComment",
        "title": "ARP: Cancel Draft Comment Edit"
      },
      {
        "command": "arp.deleteDraftComment",
        "title": "ARP: Delete Draft Comment"
      }
    ],
    "configuration": {
      "title": "Agent Review Protocol",
      "properties": {
        "arp.referenceServerCommand": {
          "type": "string",
          "default": "arp-reference-server",
          "description": "Command used to start the ARP reference server."
        },
        "arp.referenceServerTimeoutMs": {
          "type": "number",
          "default": 10000,
          "minimum": 1000,
          "description": "Timeout in milliseconds for reference server RPC calls."
        },
        "arp.busDbPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to the local SQLite ARP bus database. Defaults to .arp/bus/arp.db in the current workspace."
        },
        "arp.busWaitTimeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 0,
          "description": "How long Submit Review to Bus waits for a matching revision.proposed event before falling back to enqueue-only confirmation."
        },
        "arp.busPollIntervalMs": {
          "type": "number",
          "default": 500,
          "minimum": 50,
          "description": "Polling interval in milliseconds while waiting for a matching revision.proposed event."
        },
        "arp.autoStartBusWorkerLoop": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start or reuse a local ARP bus worker loop when submitting a review to the bus."
        },
        "arp.busWorkerLoopCommand": {
          "type": "string",
          "default": "",
          "description": "Optional command used to start the persistent ARP bus worker loop. If empty, the extension tries to find scripts/arp-bus-worker-loop in the local repo checkout."
        },
        "arp.busWorkerLoopPollIntervalMs": {
          "type": "number",
          "default": 1000,
          "minimum": 50,
          "description": "Polling interval passed to the persistent ARP bus worker loop."
        }
      }
    },
    "views": {
      "explorer": [
        {
          "id": "arpReviewFiles",
          "name": "ARP Review Files"
        }
      ]
    },
    "menus": {
      "comments/commentThread/context": [
        {
          "command": "arp.createDraftComment",
          "group": "inline@1",
          "when": "commentController == arp-review"
        }
      ],
      "comments/comment/title": [
        {
          "command": "arp.editDraftComment",
          "group": "inline@1",
          "when": "commentController == arp-review && comment == arp-draft-comment"
        },
        {
          "command": "arp.deleteDraftComment",
          "group": "inline@2",
          "when": "commentController == arp-review && comment == arp-draft-comment"
        }
      ],
      "comments/comment/context": [
        {
          "command": "arp.saveDraftComment",
          "group": "inline@1",
          "when": "commentController == arp-review && comment == arp-draft-comment"
        },
        {
          "command": "arp.cancelEditDraftComment",
          "group": "inline@2",
          "when": "commentController == arp-review && comment == arp-draft-comment"
        }
      ],
      "view/title": [
        {
          "command": "arp.refreshReviewFiles",
          "group": "navigation",
          "when": "view == arpReviewFiles"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@arp/protocol": "workspace:*",
    "@arp/store-sqlite": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.90.0"
  }
}
