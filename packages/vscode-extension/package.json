{
  "name": "arp-vscode-extension",
  "displayName": "Agent Review Protocol",
  "description": "VS Code client for the Agent Review Protocol",
  "version": "0.0.1",
  "type": "module",
  "publisher": "nodeselector",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:arp.startSession",
    "onCommand:arp.addDraftComment",
    "onCommand:arp.showDraftComments",
    "onCommand:arp.clearDraftComments",
    "onCommand:arp.submitStubReview",
    "onCommand:arp.submitReviewToBus",
    "onCommand:arp.showLatestBusRevision",
    "onCommand:arp.showOutput"
  ],
  "main": "./dist/vscode-extension/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "arp.startSession",
        "title": "ARP: Start Session"
      },
      {
        "command": "arp.addDraftComment",
        "title": "ARP: Add Draft Comment at Cursor"
      },
      {
        "command": "arp.showDraftComments",
        "title": "ARP: Show Draft Comments"
      },
      {
        "command": "arp.clearDraftComments",
        "title": "ARP: Clear Draft Comments"
      },
      {
        "command": "arp.submitStubReview",
        "title": "ARP: Submit Stub Review"
      },
      {
        "command": "arp.submitReviewToBus",
        "title": "ARP: Submit Review to Bus"
      },
      {
        "command": "arp.showLatestBusRevision",
        "title": "ARP: Show Latest Bus Revision"
      },
      {
        "command": "arp.showOutput",
        "title": "ARP: Show Output"
      }
    ],
    "configuration": {
      "title": "Agent Review Protocol",
      "properties": {
        "arp.referenceServerCommand": {
          "type": "string",
          "default": "arp-reference-server",
          "description": "Command used to start the ARP reference server."
        },
        "arp.adapterCommand": {
          "type": "string",
          "default": "arp-pi-adapter",
          "description": "Command used to start the ARP adapter for review submission."
        },
        "arp.referenceServerTimeoutMs": {
          "type": "number",
          "default": 10000,
          "minimum": 1000,
          "description": "Timeout in milliseconds for reference server RPC calls."
        },
        "arp.adapterTimeoutMs": {
          "type": "number",
          "default": 60000,
          "minimum": 1000,
          "description": "Timeout in milliseconds for adapter RPC calls."
        },
        "arp.busDbPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to the local SQLite ARP bus database. Defaults to .arp/bus/arp.db in the current workspace."
        },
        "arp.busWaitTimeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 0,
          "description": "How long Submit Review to Bus waits for a matching revision.proposed event before falling back to enqueue-only confirmation."
        },
        "arp.busPollIntervalMs": {
          "type": "number",
          "default": 500,
          "minimum": 50,
          "description": "Polling interval in milliseconds while waiting for a matching revision.proposed event."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@arp/protocol": "workspace:*",
    "@arp/store-sqlite": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.90.0"
  }
}
